{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "decirepo:conformance-report-schema:v0.1",
  "title": "DeciRepo Conformance Report v0.1",
  "type": "object",
  "required": [
    "report_schema",
    "implementation_name",
    "implementation_version",
    "conformance_profile",
    "protocol_specification",
    "protocol_semantics",
    "vectors_total",
    "vectors_passed",
    "vectors_failed",
    "overall_verdict",
    "results"
  ],
  "additionalProperties": false,
  "properties": {
    "report_schema": {
      "const": "decirepo-conformance-report-v0.1"
    },
    "implementation_name": {
      "type": "string"
    },
    "implementation_version": {
      "type": "string"
    },
    "conformance_profile": {
      "const": "V0_1"
    },
    "protocol_specification": {
      "const": "v0.2"
    },
    "protocol_semantics": {
      "const": "v0.1"
    },
    "vectors_total": {
      "type": "integer",
      "minimum": 0
    },
    "vectors_passed": {
      "type": "integer",
      "minimum": 0
    },
    "vectors_failed": {
      "type": "integer",
      "minimum": 0
    },
    "overall_verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL", "CONFORMANCE_ERROR"]
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "vector_id",
          "verdict",
          "identity_check",
          "verification_check",
          "result_bytes_check",
          "diagnostics"
        ],
        "additionalProperties": false,
        "properties": {
          "vector_id": {
            "type": "string"
          },
          "verdict": {
            "type": "string",
            "enum": ["PASS", "FAIL", "CONFORMANCE_ERROR"]
          },
          "identity_check": {
            "type": "boolean"
          },
          "verification_check": {
            "type": "boolean"
          },
          "result_bytes_check": {
            "type": "boolean"
          },
          "diagnostics": {
            "type": "object",
            "required": [
              "command",
              "reason_text",
              "failure_keys",
              "checks"
            ],
            "additionalProperties": false,
            "properties": {
              "command": {
                "type": "string"
              },
              "reason_text": {
                "type": "string"
              },
              "failure_keys": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "checks": {
                "type": "object"
              },
              "manifest": {
                "type": "object"
              },
              "raw_result": {
                "type": "object"
              },
              "expected_normalized_result": {
                "type": "object"
              },
              "actual_normalized_result": {
                "type": "object"
              },
              "unmapped_errors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
