      "evidence_manifest_sha256_uri",
      "rebuild_source",
      "rebuild_hash_expected",
      "transition_chain"
    ]
  },
  "normalized_result": {
    "schema": "decirepo-verifier-result-v0.1",
    "canonicalization": "decirepo-result-c14n-v1",
    "statuses": [
      "PASS",
      "FAIL",
      "CONFORMANCE_ERROR"
    ],
    "reason_code_ordering": {
      "mode": "fixed_total_order",
