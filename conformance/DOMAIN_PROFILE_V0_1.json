    "reason_code_normalization": {
      "mode": "fixed_total_order_then_deduplicate",
      "deduplicate_after_ordering": true,
      "duplicate_policy": "collapse_duplicates_preserving_first_ordered_position"
    }
  },
  "protocol_defined_reason_codes": [
    "SCHEMA_VERSION_INVALID",
    "ARTIFACT_HASH_INVALID",
    "VALIDATOR_RESULT_INVALID",
    "REBUILD_RESULT_INVALID",
    "PASS_REQUIRES_MATCH",
    "REBUILD_HASH_EXPECTED_MISMATCH",
    "REBUILD_SOURCE_INVALID",
    "TRANSITION_CHAIN_INVALID"
  ],
  "command_domain": {
    "verify": {
      "in_domain_when": [
        "artifact is a JSON object",
        "artifact.rebuild_source is present and usable as the published identity surface",
        "verification command is verify"
      ],
      "baseline_rules": [
        "schema_version must equal dlx-artifact-v0.1",
        "if rebuild_hash_expected is present, it must equal the computed artifact_id",
        "validator_result = PASS requires rebuild_result = MATCH"
      ]
    },
    "validate": {
      "in_domain_when": [
        "artifact is a JSON object",
        "artifact.rebuild_source is present and usable as the published identity surface",
        "verification command is validate"
      ],
      "baseline_rules": [
        "transition_chain must be a non-empty array",
        "each transition step must contain from, to, and evidence_hash",
        "allowed local transitions are DRAFT->PROPOSED, PROPOSED->VALIDATED, VALIDATED->PUBLISHED",
        "transition_chain continuity is mandatory"
      ]
    },
    "rebuild": {
      "in_domain_when": [
        "artifact is a JSON object",
        "verification command is rebuild"
      ],
      "baseline_rules": [
        "rebuild_source must be present",
        "rebuild_source must be an object"
      ]
    }
  },
  "unknown_field_policy": {
    "artifact_envelope_fields_outside_rebuild_source": {
      "affect_identity_surface": false,
      "affect_normalized_result_surface": false,
      "published_anchor": "vector_007_unknown_envelope_field"
    },
    "fields_inside_rebuild_source": {
      "participate_in_identity_surface": true,
      "notes": [
        "Fields inside rebuild_source are inside the identity surface unless a future profile states otherwise."
      ]
    },
    "normalized_result_object": {
      "unknown_fields_forbidden_in_conformance": true
    }
  },
  "out_of_scope_cases": [
    {
      "case_id": "verify_without_rebuild_source",
      "treatment": "outside_published_baseline_conformance_path"
    },
    {
      "case_id": "unsupported_verification_command",
      "treatment": "conformance_harness_error"
    }
  ],
  "open_gaps": [
    "No published canonical vector yet anchors a natural CONFORMANCE_ERROR case.",
    "No published canonical vector yet anchors absent rebuild_source under verify.",
    "No published canonical vector yet anchors multi-reason precedence behavior.",
    "Reason-code coverage for ARTIFACT_HASH_INVALID, VALIDATOR_RESULT_INVALID, and REBUILD_RESULT_INVALID is registry-only at this profile stage."
