    "canonical_bytes_source": "artifact.rebuild_source",
    "identity_canonicalization": "decirepo-json-c14n-v1",
    "artifact_id_function": "SHA256(decirepo-json-c14n-v1(artifact.rebuild_source))",
    "baseline_compatible_conformance_path": {
      "requires_rebuild_source_present": true,
      "requires_rebuild_source_usable_as_identity_surface": true,
      "requires_supported_command": true,
      "notes": [
        "Published baseline compatibility is claimed only on artifacts whose identity surface resolves to artifact.rebuild_source.",
